{
  "name": "@takumi-rs/core",
  "version": "1.8.7",
  "description": "Native Node.js bindings for the Takumi Rust image rendering engine.",
  "keywords": [
    "css",
    "image",
    "jsx",
    "napi",
    "nodejs",
    "og-image",
    "react",
    "rendering"
  ],
  "homepage": "https://takumi.kane.tw/docs/integration",
  "bugs": {
    "url": "https://github.com/kane50613/takumi/issues"
  },
  "license": "(MIT OR Apache-2.0)",
  "author": {
    "name": "Kane Wang",
    "email": "me@kane.tw",
    "url": "https://kane.tw"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kane50613/takumi.git",
    "directory": "takumi-napi-core"
  },
  "files": [
    "dist",
    "index.d.ts",
    "not-available.js"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/export.cjs",
  "module": "./dist/export.mjs",
  "types": "./dist/export.d.mts",
  "exports": {
    ".": {
      "workerd": {
        "types": "./dist/export.d.mts",
        "default": "./not-available.js"
      },
      "browser": {
        "types": "./dist/export.d.mts",
        "default": "./not-available.js"
      },
      "import": {
        "types": "./dist/export.d.mts",
        "default": "./dist/export.mjs"
      },
      "require": {
        "types": "./dist/export.d.cts",
        "default": "./dist/export.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "napi build --release --no-const-enum --platform --esm --strip",
    "build:js": "tsdown && bun scripts/patch-dist-loader.ts",
    "prepublishOnly": "jq '.dependencies[\"@takumi-rs/helpers\"] = .version' package.json > tmp.json && mv tmp.json package.json && bun artifacts && napi prepublish -t npm --no-gh-release",
    "artifacts": "napi create-npm-dirs && napi artifacts && napi version",
    "bench": "bun tests/bench/index.tsx",
    "publish-lint": "attw --pack . && publint --strict ."
  },
  "dependencies": {
    "@takumi-rs/helpers": "1.8.7"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.7.0",
    "@types/bun": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "csstype": "^3.2.3",
    "lucide-react": "catalog:",
    "mitata": "^1.0.34",
    "react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "unrun": "catalog:"
  },
  "napi": {
    "binaryName": "core",
    "dtsHeaderFile": "./src/dts-header.d.ts",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 12.22.0 < 13 || >= 14.17.0 < 15 || >= 15.12.0 < 16 || >= 16.0.0"
  },
  "optionalDependencies": {
    "@takumi-rs/core-darwin-x64": "1.8.7",
    "@takumi-rs/core-darwin-arm64": "1.8.7",
    "@takumi-rs/core-linux-arm64-gnu": "1.8.7",
    "@takumi-rs/core-linux-arm64-musl": "1.8.7",
    "@takumi-rs/core-win32-arm64-msvc": "1.8.7",
    "@takumi-rs/core-linux-x64-gnu": "1.8.7",
    "@takumi-rs/core-linux-x64-musl": "1.8.7",
    "@takumi-rs/core-win32-x64-msvc": "1.8.7"
  }
}